# Secrets only - all other config is in code (playwright/support/config/environments.ts)
# Choose one block to target dev/prod/local and fill in the placeholders.

# Dev (cloud) - default
SUPABASE_URL=https://your-dev-ref.supabase.co
SUPABASE_ANON_KEY=your-dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-dev-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key

# PostHog (canonical source of truth for web + mobile)
# apps/web and apps/mobile read these canonical vars.
# apps/mobile reads these through app config extra values.
POSTHOG_API_KEY=phc_your_project_key
POSTHOG_HOST=https://us.i.posthog.com

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
# For Upstash/Prod, set REDIS_TLS=true and REDIS_URL=rediss://:<token>@<host>:<port>
REDIS_TLS=false

UPSTASH_REDIS_REST_URL=***
UPSTASH_REDIS_REST_TOKEN=***

# Expo Push
# EXPO_TOKEN: create an access token in Expo (Account Settings → Access Tokens or `npx eas token:create`).
# Used by EAS workflows and the API push client.
EXPO_TOKEN=your-expo-access-token

# Vercel Preview protection bypass (optional)
# If Vercel Preview deployments are protected, create a 32-character bypass secret in Vercel and set it here (and in CI).
VERCEL_AUTOMATION_BYPASS_SECRET=your-32-character-bypass-secret

# Vercel Preview URL discovery (optional)
# If set, `TEST_ENV=dev` can derive the stable per-branch Preview URL when `DEV_WEB_E2E_BASE_URL` is not set.
VERCEL_WEB_PROJECT_SLUG=couture-cast-web
VERCEL_API_PROJECT_SLUG=couture-cast-api
VERCEL_TEAM_SLUG=muratkeremozcans-projects

SUPABASE_DB_DEV_PW=your-dev-db-password

SUPABASE_DB_PROD_PW=your-prod-db-password

DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# Guardian invitation flow
# GUARDIAN_INVITE_WEB_BASE_URL powers links like https://app.couturecast.test/guardian/accept?token=...
GUARDIAN_INVITE_WEB_BASE_URL=http://localhost:3000
# GUARDIAN_INVITE_JWT_SECRET signs 7-day guardian invitation tokens.
GUARDIAN_INVITE_JWT_SECRET=your-guardian-invite-jwt-secret
# Defaults to true so adult accounts automatically drop guardian-linked access on the 18th birthday sweep.
GUARDIAN_EMANCIPATION_REVOKE_CONSENTS=true

# Optional local Grafana stack for OTEL traces + metrics
# Start it with: npm run observability:local:up
# Then point the API OTLP exporter at the local LGTM endpoint.
# GRAFANA_OTLP_ENDPOINT=http://127.0.0.1:4318
# GRAFANA_OTLP_AUTH_HEADER=disabled
# OTEL_SERVICE_NAME=couturecast-api
