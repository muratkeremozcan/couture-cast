{
  "name": "@couture/api-client",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "description": "Shared API client types and schemas",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./realtime/*": {
      "types": "./dist/realtime/*.d.ts",
      "default": "./dist/realtime/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    },
    "./contracts/http": {
      "types": "./dist/contracts/http/index.d.ts",
      "default": "./dist/contracts/http/index.js"
    },
    "./contracts/http/*": {
      "types": "./dist/contracts/http/*.d.ts",
      "default": "./dist/contracts/http/*.js"
    },
    "./testing/*": {
      "types": "./dist/testing/*.d.ts",
      "default": "./dist/testing/*.js"
    }
  },
  "scripts": {
    "build": "rimraf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "lint": "eslint --max-warnings=0 --ext .ts src scripts testing",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "gen:openapi:events": "tsx scripts/generate-events-openapi.ts",
    "gen:openapi:http": "tsx scripts/generate-http-openapi.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "ts-node": "^10.9.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0"
  }
}
