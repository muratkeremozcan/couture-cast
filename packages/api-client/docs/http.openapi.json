{
  "openapi": "3.1.0",
  "info": {
    "title": "CoutureCast HTTP API",
    "version": "0.1.0",
    "description": "Canonical HTTP contracts shared across API, web, mobile, and tests."
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Local development server"
    }
  ],
  "components": {
    "schemas": {
      "ApiError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "error"
        ]
      },
      "TrackedResponse": {
        "type": "object",
        "properties": {
          "tracked": {
            "type": "boolean",
            "enum": [
              true
            ]
          }
        },
        "required": [
          "tracked"
        ]
      },
      "BadRequestHttpError": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "enum": [
              400
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "error": {
            "type": "string",
            "enum": [
              "Bad Request"
            ]
          }
        },
        "required": [
          "statusCode",
          "message",
          "error"
        ]
      },
      "UnauthorizedHttpError": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "enum": [
              401
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "error": {
            "type": "string",
            "enum": [
              "Unauthorized"
            ]
          }
        },
        "required": [
          "statusCode",
          "message",
          "error"
        ]
      },
      "ForbiddenHttpError": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "enum": [
              403
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "error": {
            "type": "string",
            "enum": [
              "Forbidden"
            ]
          }
        },
        "required": [
          "statusCode",
          "message",
          "error"
        ]
      },
      "NotFoundHttpError": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "enum": [
              404
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "error": {
            "type": "string",
            "enum": [
              "Not Found"
            ]
          }
        },
        "required": [
          "statusCode",
          "message",
          "error"
        ]
      },
      "SignupInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "birthdate": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        },
        "required": [
          "email",
          "birthdate"
        ]
      },
      "SignupResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "minLength": 1
          },
          "age": {
            "type": "integer",
            "minimum": 13
          },
          "accountStatus": {
            "type": "string",
            "enum": [
              "active",
              "pending_guardian_consent"
            ]
          },
          "guardianConsentRequired": {
            "type": "boolean"
          }
        },
        "required": [
          "userId",
          "age",
          "accountStatus",
          "guardianConsentRequired"
        ]
      },
      "GuardianConsentInput": {
        "type": "object",
        "properties": {
          "guardianId": {
            "type": "string",
            "minLength": 1
          },
          "teenId": {
            "type": "string",
            "minLength": 1
          },
          "consentLevel": {
            "type": "string",
            "minLength": 1
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "guardianId",
          "teenId",
          "consentLevel"
        ]
      },
      "ApiHealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          },
          "service": {
            "type": "string",
            "enum": [
              "couturecast-api"
            ]
          },
          "environment": {
            "type": "string",
            "minLength": 1
          },
          "gitSha": {
            "type": "string",
            "minLength": 1
          },
          "gitBranch": {
            "type": "string",
            "minLength": 1
          },
          "deployUrl": {
            "type": "string",
            "format": "uri"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "status",
          "service",
          "environment",
          "gitSha",
          "gitBranch",
          "timestamp"
        ]
      },
      "QueueMetrics": {
        "type": "object",
        "properties": {
          "waiting": {
            "type": "integer",
            "minimum": 0
          },
          "active": {
            "type": "integer",
            "minimum": 0
          },
          "completed": {
            "type": "integer",
            "minimum": 0
          },
          "failed": {
            "type": "integer",
            "minimum": 0
          },
          "delayed": {
            "type": "integer",
            "minimum": 0
          },
          "paused": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "QueueHealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          },
          "queues": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "metrics": {
            "type": "object",
            "properties": {
              "waiting": {
                "type": "integer",
                "minimum": 0
              },
              "active": {
                "type": "integer",
                "minimum": 0
              },
              "completed": {
                "type": "integer",
                "minimum": 0
              },
              "failed": {
                "type": "integer",
                "minimum": 0
              },
              "delayed": {
                "type": "integer",
                "minimum": 0
              },
              "paused": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "required": [
          "status",
          "queues",
          "metrics"
        ]
      },
      "PolledEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "channel": {
            "type": "string",
            "minLength": 1
          },
          "payload": {},
          "userId": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "channel",
          "userId",
          "createdAt"
        ]
      },
      "EventsPollQuery": {
        "type": "object",
        "properties": {
          "since": {
            "type": "string",
            "format": "date-time",
            "description": "Fetch only events created after this ISO timestamp."
          }
        }
      },
      "EventsPollResponse": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PolledEvent"
            }
          },
          "nextSince": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "events",
          "nextSince"
        ]
      },
      "EventsPollInvalidSinceResponse": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PolledEvent"
            }
          },
          "nextSince": {
            "type": "null"
          },
          "error": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "events",
          "nextSince",
          "error"
        ]
      },
      "EventsPollResult": {
        "anyOf": [
          {
            "$ref": "#/components/schemas/EventsPollResponse"
          },
          {
            "$ref": "#/components/schemas/EventsPollInvalidSinceResponse"
          }
        ]
      },
      "GuardianInvitationInput": {
        "type": "object",
        "properties": {
          "teenId": {
            "type": "string",
            "minLength": 1
          },
          "guardianEmail": {
            "type": "string",
            "format": "email"
          },
          "consentLevel": {
            "type": "string",
            "enum": [
              "read_only",
              "full_access"
            ],
            "default": "read_only"
          }
        },
        "required": [
          "teenId",
          "guardianEmail"
        ]
      },
      "GuardianInvitationResponse": {
        "type": "object",
        "properties": {
          "invitationId": {
            "type": "string",
            "minLength": 1
          },
          "teenId": {
            "type": "string",
            "minLength": 1
          },
          "guardianEmail": {
            "type": "string",
            "format": "email"
          },
          "consentLevel": {
            "type": "string",
            "enum": [
              "read_only",
              "full_access"
            ]
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "invitationLink": {
            "type": "string",
            "format": "uri"
          },
          "deliveryQueued": {
            "type": "boolean"
          }
        },
        "required": [
          "invitationId",
          "teenId",
          "guardianEmail",
          "consentLevel",
          "expiresAt",
          "invitationLink",
          "deliveryQueued"
        ]
      },
      "GuardianInvitationAcceptInput": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "token"
        ]
      },
      "GuardianInvitationAcceptResponse": {
        "type": "object",
        "properties": {
          "teenId": {
            "type": "string",
            "minLength": 1
          },
          "teenEmail": {
            "type": "string",
            "format": "email"
          },
          "guardianId": {
            "type": "string",
            "minLength": 1
          },
          "guardianEmail": {
            "type": "string",
            "format": "email"
          },
          "consentLevel": {
            "type": "string",
            "enum": [
              "read_only",
              "full_access"
            ]
          },
          "grantedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "teenId",
          "teenEmail",
          "guardianId",
          "guardianEmail",
          "consentLevel",
          "grantedAt"
        ]
      },
      "ModerationActionInput": {
        "type": "object",
        "properties": {
          "moderatorId": {
            "type": "string",
            "minLength": 1
          },
          "targetId": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "contentType": {
            "type": "string",
            "minLength": 1
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "moderatorId",
          "targetId",
          "action",
          "reason"
        ]
      },
      "LinkedGuardian": {
        "type": "object",
        "properties": {
          "guardianId": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "granted",
              "revoked"
            ]
          },
          "consentGrantedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "guardianId",
          "status",
          "consentGrantedAt"
        ]
      },
      "LinkedTeen": {
        "type": "object",
        "properties": {
          "teenId": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "granted",
              "revoked"
            ]
          },
          "consentGrantedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "teenId",
          "status",
          "consentGrantedAt"
        ]
      },
      "UserProfileResponse": {
        "type": "object",
        "properties": {
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "email": {
                "type": "string",
                "format": "email"
              },
              "displayName": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "birthdate": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              },
              "role": {
                "type": "string",
                "enum": [
                  "guardian",
                  "teen",
                  "moderator",
                  "admin"
                ]
              }
            },
            "required": [
              "id",
              "email",
              "displayName",
              "birthdate",
              "role"
            ]
          },
          "linkedGuardians": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "guardianId": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "pending",
                    "granted",
                    "revoked"
                  ]
                },
                "consentGrantedAt": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date-time"
                }
              },
              "required": [
                "guardianId",
                "status",
                "consentGrantedAt"
              ]
            }
          },
          "linkedTeens": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "teenId": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "pending",
                    "granted",
                    "revoked"
                  ]
                },
                "consentGrantedAt": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "format": "date-time"
                }
              },
              "required": [
                "teenId",
                "status",
                "consentGrantedAt"
              ]
            }
          }
        },
        "required": [
          "user",
          "linkedGuardians",
          "linkedTeens"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/v1/auth/signup": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Create an account with age verification",
        "description": "Evaluates the submitted birthdate, blocks signups for children under 13, and flags 13-15 year olds for guardian consent.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignupResponse"
                }
              }
            }
          },
          "400": {
            "description": "Signup payload failed validation or email is already registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequestHttpError"
                }
              }
            }
          },
          "403": {
            "description": "Birthdate indicates a child younger than thirteen",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForbiddenHttpError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/guardian-consent": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Record guardian consent for a teen account",
        "description": "Captures guardian consent for compliance workflows and downstream audit/analytics handling.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GuardianConsentInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Guardian consent recorded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Guardian consent payload failed validation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequestHttpError"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid authentication headers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedHttpError"
                }
              }
            }
          },
          "403": {
            "description": "Authenticated guardian does not match guardianId",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForbiddenHttpError"
                }
              }
            }
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "API health metadata for smoke tests and preview waiters",
        "responses": {
          "200": {
            "description": "API deployment metadata returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ]
                    },
                    "service": {
                      "type": "string",
                      "enum": [
                        "couturecast-api"
                      ]
                    },
                    "environment": {
                      "type": "string",
                      "minLength": 1
                    },
                    "gitSha": {
                      "type": "string",
                      "minLength": 1
                    },
                    "gitBranch": {
                      "type": "string",
                      "minLength": 1
                    },
                    "deployUrl": {
                      "type": "string",
                      "format": "uri"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time"
                    }
                  },
                  "required": [
                    "status",
                    "service",
                    "environment",
                    "gitSha",
                    "gitBranch",
                    "timestamp"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/health/queues": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Queue health snapshot",
        "responses": {
          "200": {
            "description": "Configured queue names returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ]
                    },
                    "queues": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "metrics": {
                      "type": "object",
                      "properties": {
                        "waiting": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "active": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "completed": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "failed": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "delayed": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "paused": {
                          "type": "integer",
                          "minimum": 0
                        }
                      }
                    }
                  },
                  "required": [
                    "status",
                    "queues",
                    "metrics"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/events/poll": {
      "get": {
        "tags": [
          "events"
        ],
        "summary": "Poll incremental realtime fallback events",
        "description": "Returns unseen events plus the next cursor for polling fallback clients.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "date-time",
              "description": "Fetch only events created after this ISO timestamp."
            },
            "required": false,
            "description": "Fetch only events created after this ISO timestamp.",
            "name": "since",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Incremental polling result. Invalid query timestamps currently return a graceful payload instead of a 4xx.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventsPollResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/guardian/invitations": {
      "post": {
        "tags": [
          "guardian"
        ],
        "summary": "Invite a guardian for a teen account",
        "description": "Creates a signed seven-day invitation token, queues an invitation email, and stores the invitation for later acceptance.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GuardianInvitationInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Guardian invitation created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GuardianInvitationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Guardian invitation payload failed validation or the teen is not eligible",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequestHttpError"
                }
              }
            }
          },
          "404": {
            "description": "Teen account was not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundHttpError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/guardian/accept": {
      "post": {
        "tags": [
          "guardian"
        ],
        "summary": "Accept a guardian invitation",
        "description": "Validates the signed invitation token, links or creates the guardian account, records consent, and queues confirmation emails.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GuardianInvitationAcceptInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Guardian invitation accepted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GuardianInvitationAcceptResponse"
                }
              }
            }
          },
          "400": {
            "description": "Guardian invitation token is invalid, expired, or already used",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BadRequestHttpError"
                }
              }
