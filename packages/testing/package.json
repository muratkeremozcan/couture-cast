{
  "name": "@couture/testing",
  "version": "0.0.1",
  "private": true,
  "description": "Shared test fixture factories and cleanup helpers for CoutureCast",
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cleanup": {
      "types": "./dist/cleanup.d.ts",
      "default": "./dist/cleanup.js"
    },
    "./factories": {
      "types": "./dist/factories/index.d.ts",
      "default": "./dist/factories/index.js"
    },
    "./factories/*": {
      "types": "./dist/factories/*.d.ts",
      "default": "./dist/factories/*.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && npm exec --yes --package=typescript@5.9.3 -- tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "lint": "eslint --max-warnings=0 --ext .ts src templates test",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage"
  },
  "dependencies": {
    "@faker-js/faker": "10.1.0",
    "@prisma/client": "6.19.0"
  }
}
