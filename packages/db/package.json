{
  "name": "@couture/db",
  "private": true,
  "version": "0.1.0",
  "description": "CoutureCast Prisma schema, migrations, and seeds",
  "type": "module",
  "scripts": {
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force --skip-seed && prisma db seed",
    "db:studio": "prisma studio",
    "db:generate": "npx prisma generate",
    "lint": "eslint --max-warnings=0 --ext .ts prisma/seeds test vitest.config.ts",
    "typecheck": "npm run db:generate && tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@faker-js/faker": "10.1.0",
    "@prisma/client": "6.19.0"
  },
  "engines": {
    "node": ">=22"
  },
  "prisma": {
    "seed": "tsx prisma/seeds/index.ts"
  }
}
