{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "prepare:shared-config": "npm run build --workspace @couture/config",
    "vercel:build": "cd ../.. && npx prisma@6.19.0 generate --schema packages/db/prisma/schema.prisma && npm run build --workspace api",
    "prebuild": "npm run prepare:shared-config",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"integration/**/*.ts\"",
    "prestart": "npm run prepare:shared-config",
    "start": "tsx src/main.ts",
    "prestart:dev": "npm run prepare:shared-config",
    "start:dev": "tsx watch src/main.ts",
    "prestart:debug": "npm run prepare:shared-config",
    "start:debug": "tsx watch --inspect src/main.ts",
    "start:prod": "node dist/apps/api/src/main.js",
    "lint": "eslint \"{src,apps,libs,test,integration}/**/*.ts\" --fix",
    "pretypecheck": "npm run prepare:shared-config && prisma generate --schema ../../packages/db/prisma/schema.prisma",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run prepare:shared-config",
    "test": "vitest run",
    "pretest:watch": "npm run prepare:shared-config",
    "test:watch": "vitest",
    "pretest:cov": "npm run prepare:shared-config",
    "test:cov": "vitest run --coverage",
    "pretest:integration": "npm run prepare:shared-config",
    "test:integration": "vitest run integration/**/*.spec.ts",
    "prestart:workers": "npm run prepare:shared-config",
    "start:workers": "tsx src/workers/bootstrap.ts",
    "prestart:workers:prod": "npm run prepare:shared-config",
    "start:workers:prod": "node dist/apps/api/src/workers/bootstrap.js"
  },
  "dependencies": {
    "@couture/config": "file:../../packages/config",
    "@nestjs/common": "11.1.9",
    "@nestjs/core": "11.1.9",
    "@nestjs/platform-express": "11.1.9",
    "@nestjs/platform-socket.io": "^11.1.9",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/websockets": "^11.1.9",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "bullmq": "^5.65.0",
    "expo-server-sdk": "^4.0.0",
    "ioredis": "^5.8.2",
    "pino": "^9.4.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "posthog-node": "^5.21.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "^4.8.1",
    "testcontainers": "^11.9.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "2.1.4",
    "@eslint/js": "8.57.1",
    "@nestjs/cli": "11.0.10",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.9",
    "@types/express": "5.0.5",
    "@types/node": "22.9.3",
    "@types/supertest": "6.0.3",
    "@vitest/coverage-v8": "4.0.9",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "globals": "13.24.0",
    "prettier": "3.6.2",
    "source-map-support": "0.5.21",
    "supertest": "7.1.4",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "3.15.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.4",
    "vitest": "4.0.9"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
