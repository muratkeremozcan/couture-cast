<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_temperature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk"
            android:text="--"
            android:textColor="#111111"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_condition"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/space_grotesk"
            android:gravity="end"
            android:text="?"
            android:textColor="#C9A14A"
            android:textSize="20sp" />
    </LinearLayout>

    <View
        android:layout_width="30dp"
        android:layout_height="2dp"
        android:layout_marginBottom="5dp"
        android:layout_marginTop="5dp"
        android:background="#C9A14A" />

    <TextView
        android:id="@+id/widget_now_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/space_grotesk"
        android:letterSpacing="0.1"
        android:text="NOW"
        android:textColor="#111111"
        android:textSize="9sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_outfit_summary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="3dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:fontFamily="@font/space_grotesk"
        android:maxLines="3"
        android:text="Open app for recommendations"
        android:textColor="#B8111111"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/widget_stale"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/space_grotesk"
        android:text="Stale"
        android:textColor="#C9A14A"
        android:textSize="9sp"
        android:textStyle="bold"
        android:visibility="gone" />
</LinearLayout>
