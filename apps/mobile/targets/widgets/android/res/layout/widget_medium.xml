<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/widget_now_section"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_temperature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:text="--"
                android:textColor="#111111"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_condition"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/space_grotesk"
                android:gravity="end"
                android:text="?"
                android:textColor="#C9A14A"
                android:textSize="17sp" />
        </LinearLayout>

        <View
            android:layout_width="24dp"
            android:layout_height="2dp"
            android:layout_marginBottom="4dp"
            android:layout_marginTop="4dp"
            android:background="#C9A14A" />

        <TextView
            android:id="@+id/widget_now_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk"
            android:letterSpacing="0.1"
            android:text="NOW"
            android:textColor="#111111"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_outfit_summary"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="@font/space_grotesk"
            android:maxLines="2"
            android:text="Open app for recommendations"
            android:textColor="#B8111111"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_stale"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk"
            android:text="Stale"
            android:textColor="#C9A14A"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#E6E6ED" />

    <LinearLayout
        android:id="@+id/widget_next_section"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_next_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:fontFamily="@font/space_grotesk"
                android:text="?"
                android:textColor="#C9A14A"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/widget_next_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk"
                android:text="--"
                android:textColor="#111111"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_next_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/space_grotesk"
                android:gravity="end"
                android:text=""
                android:textColor="#9E111111"
                android:textSize="9sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_next_precipitation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/space_grotesk"
            android:maxLines="1"
            android:text="Precipitation --"
            android:textColor="#9E111111"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_next_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk"
            android:letterSpacing="0.08"
            android:text="NEXT HOUR"
            android:textColor="#111111"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_next_outfit_summary"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="@font/space_grotesk"
            android:maxLines="2"
            android:text="Open app for recommendations"
            android:textColor="#B8111111"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
