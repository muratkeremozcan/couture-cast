{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "jsx": "preserve",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@couture/config": ["../../packages/config/src/index.ts"],
      "@couture/utils": ["../../packages/utils/src/index.ts"],
      "@couture/api-client": ["../../packages/api-client/src/index.ts"],
      "@couture/api-client/contracts/http": [
        "../../packages/api-client/src/contracts/http/index.ts"
      ],
      "@couture/api-client/contracts/http/*": [
        "../../packages/api-client/src/contracts/http/*"
      ],
      "@couture/api-client/testing/*": ["../../packages/api-client/src/testing/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
