{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare:shared-deps": "npm run build --workspace @couture/utils && npm run build --workspace @couture/api-client",
    "predev": "npm run prepare:shared-deps",
    "prebuild": "npm run prepare:shared-deps",
    "prestart": "npm run prepare:shared-deps",
    "pretypecheck": "npm run prepare:shared-deps",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "previtest:run": "npm run prepare:shared-deps",
    "vitest:run": "vitest run --config vitest.config.ts",
    "previtest:browser:run": "npm run prepare:shared-deps",
    "vitest:browser:run": "vitest run --config vitest.headless.config.ts",
    "previtest:open": "npm run prepare:shared-deps",
    "vitest:open": "vitest --config vitest.browser.config.ts",
    "test": "npm run vitest:run",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "dev": "node ../../node_modules/next/dist/bin/next dev",
    "build": "node ../../node_modules/next/dist/bin/next build",
    "start": "node ../../node_modules/next/dist/bin/next start",
    "lint": "cd ../.. && eslint --max-warnings=0 --ext .ts,.tsx apps/web"
  },
  "dependencies": {
    "@couture/api-client": "file:../../packages/api-client",
    "@couture/utils": "file:../../packages/utils",
    "next": "15.5.9",
    "posthog-js": "^1.356.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "19.1.17",
    "@types/react-dom": "18.3.7",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint-config-next": "15.5.9",
    "jsdom": "^27.0.1",
    "msw": "^2.12.10",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.18",
    "vite": "^6.4.1"
  }
}
